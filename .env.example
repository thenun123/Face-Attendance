# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
APP_VERSION=2.0.0
TIMEZONE=Asia/Karachi

# ── Supabase / PostgreSQL ─────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI)
# Use the "Transaction" mode pooler URL (port 6543) for serverless/free tier
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── ImageKit ──────────────────────────────────────────────────────────────────
# Get from: ImageKit Dashboard → Developer Options → API Keys
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_UPLOAD_FOLDER=/face_attendance/unknown_faces

# ── Recognition ───────────────────────────────────────────────────────────────
RECOGNITION_THRESHOLD=0.65
CONFIRM_FRAMES=3
ANTI_SPAM_MINUTES=5

# ── Shift Defaults ────────────────────────────────────────────────────────────
DEFAULT_SHIFT_START=09:00
DEFAULT_SHIFT_END=17:00
LATE_GRACE_MINUTES=10
HALF_DAY_HOUR=11

# ── ML Model ──────────────────────────────────────────────────────────────────
MODEL_NAME=vggface2
CAMERA_INDEX=0

# ── Security ──────────────────────────────────────────────────────────────────
# Token required to hit /auth/setup-admin. Leave empty to disable the endpoint.
SETUP_TOKEN=
# Comma-separated CORS origins. Falls back to localhost:3000,3001 if empty.
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
